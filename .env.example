# open-brain Konfiguration
# Kopiere diese Datei zu .env und fülle die Werte aus

# Pflicht: OpenRouter API-Key
# Format: sk-or-v1-xxxx...
# Hol dir einen Key unter: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: Pfad zur Datenbankdatei
# Default: ./brain.db (im open-brain Verzeichnis)
# OPENBRAIN_DB_PATH=/path/to/brain.db

# Optional: Rate-Limit für OpenRouter API (Calls pro Sekunde)
# Default: 2.0
# OPENROUTER_RATE_LIMIT=2.0
